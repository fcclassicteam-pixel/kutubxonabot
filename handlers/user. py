# ---------- BOOK INFO / SEND FILE ----------

@router.callback_query(F.data.startswith("info:"))
async def book_info(callback: CallbackQuery):
    book_id = int(callback.data.split(":")[1])
    book = await db.get_book(book_id)
    if not book:
        await callback.answer("Kitob topilmadi.", show_alert=True)
        return
    await callback.answer()
    if book["price"]:
        await callback.message.answer(
            f"💰 Bu kitob pullik ({book['price']:,} so'm). ".replace(",", " ") +
            "Buyurtma qilish uchun \"🛒 Kitob buyurtma qilish\" bo'limidan foydalaning."
        )
        return
    if book["book_type"] == "audio":
        await callback.message.answer_audio(book["file_id"], caption=book["title"])
    else:
        await callback.message.answer_document(book["file_id"], caption=book["title"])


