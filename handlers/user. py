# ---------- SEARCH ----------

@router.message(F.text == "🔍 Qidirish")
async def search_start(message: Message, state: FSMContext):
    await state.set_state(SearchBook.query)
    await message.answer("Kitob nomi yoki muallifini yozing:", reply_markup=kb.cancel_kb())


@router.message(SearchBook.query)
async def search_process(message: Message, state: FSMContext):
    await state.clear()
    results = await db.search_books(message.text.strip())
    if not results:
        await message.answer("😕 Hech narsa topilmadi.", reply_markup=kb.main_menu(message.from_user.id))
        return
    await message.answer(f"🔎 {len(results)} ta natija topildi:", reply_markup=kb.main_menu(message.from_user.id))
    for book in results[:10]:
        await send_book_card(message, book)


async def send_book_card(message: Message, book):
    avg, count = await db.get_book_rating(book["id"])
    price_text = "🆓 Bepul" if not book["price"] else f"💰 {book['price']:,} so'm".replace(",", " ")
    type_text = "🎧 Audio" if book["book_type"] == "audio" else "📖 Matnli"
    author_text = book["author"] or "Muallif noma'lum"
    caption = (
        f"<b>{book['title']}</b>\n"
        f"✍️ {author_text}\n"
        f"🏷 {book['genre'] or '-'}  |  {type_text}\n"
        f"⭐ {avg}/5 ({count} baho)\n"
        f"{price_text}\n\n"
        f"{(book['description'] or '')[:300]}"
    )
    if book["cover_file_id"]:
        await message.answer_photo(book["cover_file_id"], caption=caption, reply_markup=kb.book_card_kb(book["id"]))
    else:
        await message.answer(caption, reply_markup=kb.book_card_kb(book["id"]))


# ---------- GENRES ----------

@router.message(F.text == "📚 Janrlar")
async def genres_list(message: Message):
    genres = await db.get_genres()
    if not genres:
        await message.answer("Hozircha janrlar mavjud emas.")
        return
    await message.answer("Janrni tanlang:", reply_markup=kb.genres_inline(genres))


@router.callback_query(F.data.startswith("genre:"))
async def genre_books(callback: CallbackQuery):
    _, genre, offset = callback.data.split(":")
    offset = int(offset)
    books = await db.get_books_by_genre(genre, offset, PAGE_SIZE)
    if not books:
        await callback.answer("Bu janrda kitob topilmadi.", show_alert=True)
        return
    await callback.answer()
    for book in books:
        await send_book_card(callback.message, book)
    has_more = len(books) == PAGE_SIZE
    nav_kb = kb.pagination_kb("genre", genre, offset, PAGE_SIZE, has_more)
    if nav_kb.inline_keyboard:
        await callback.message.answer("Ko'proq ko'rish:", reply_markup=nav_kb)


